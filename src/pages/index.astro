---
import '../styles/global.css';

const name = "Andrew Schoneweis";
const email = "schoneweis@gmail.com";
const siteUrl = "https://andrewschoneweis.com";
const description = "Andrew Schoneweis — UX Designer at YouTube, designing Search and AI experiences for the TV.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": name,
  "url": siteUrl,
  "jobTitle": "UX Designer",
  "worksFor": {
    "@type": "Organization",
    "name": "Google",
    "url": "https://google.com"
  },
  "description": "UX Designer at Google's YouTube Living Room team, designing Search and AI experiences for TV and home devices.",
  "email": email,
  "sameAs": [
    "https://www.linkedin.com/in/schoneweis"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Andrew Schoneweis</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={siteUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content="Andrew Schoneweis" />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/andrew.jpg`} />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Andrew Schoneweis" />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}/andrew.jpg`} />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <main>

    <section class="hero">
      <h1>Hi, I'm Andrew.</h1>
      <p class="tagline">UX Designer on the YouTube Living Room team, designing Search and AI experiences for the TV.</p>
      <img src="/andrew.jpg" alt="Andrew Schoneweis" class="headshot" />
    </section>

    <section class="about">
      <h2>About</h2>
      <p>
        I'm a designer based in Mountain View, California. I've spent the past nine years as a 
        UX designer at Google, creating multi-modal, AI-driven experiences for TVs and home devices.
      </p>
    </section>

    <section class="contact">
      <h2>Say hello</h2>
      <p>Feel free to connect and reach out!</p>
      <p>→ <a href={`mailto:${email}`}>{email}</a></p>
      <p>→ <a href="https://www.linkedin.com/in/schoneweis" target="_blank" rel="noopener noreferrer">LinkedIn</a></p>
    </section>

  </main>

  <footer>
    <p>Andrew Schoneweis &bull; {new Date().getFullYear()}</p>
  </footer>
</body>
</html>
